# ==========================================
# PRODUCTION PAYMENT INTEGRATION CONFIG
# ==========================================

# --- NODE ENVIRONMENT ---
NODE_ENV=production
PORT=3000
HTTPS_ENABLED=true

# --- DATABASE CONFIGURATION ---
DB_HOST=localhost
DB_USER=root
DB_PASS=your_secure_password
DB_NAME=webtokobajuu
DB_PORT=3306

# --- MIDTRANS PAYMENT GATEWAY ---
# Get from: https://dashboard.midtrans.com (Sandbox/Production)
# SANDBOX (Development/Testing)
MIDTRANS_SANDBOX_SERVER_KEY=SB-Mid-server-xxxxxxxxxxxxxxxxxxxx
MIDTRANS_SANDBOX_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxxxxxxxxxx

# PRODUCTION (Live)
MIDTRANS_SERVER_KEY=Mid-server-xxxxxxxxxxxxxxxxxxxx
MIDTRANS_CLIENT_KEY=Mid-client-xxxxxxxxxxxxxxxxxxxx

# --- PAYMENT WEBHOOK SECURITY (REQUIRED) ---
# Generate: openssl rand -base64 32
MIDTRANS_WEBHOOK_SECRET=your_super_secure_webhook_secret_minimum_32_chars_!!!

# Webhook IP whitelist (comma-separated, for production use Midtrans IPs)
MIDTRANS_WEBHOOK_IP_WHITELIST=127.0.0.1

# --- PAYMENT CALLBACK URLS (HTTPS Required for Production) ---
PAYMENT_SUCCESS_URL=https://yourdomain.com/payment-success.html
PAYMENT_FAILURE_URL=https://yourdomain.com/payment-failure.html
PAYMENT_PENDING_URL=https://yourdomain.com/payment-pending.html
PAYMENT_WEBHOOK_URL=https://yourdomain.com/api/payment/webhook

# --- ENCRYPTION (Optional: for sensitive data) ---
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=your_32_char_hex_key_for_sensitive_data

# --- LOGGING & MONITORING ---
LOG_LEVEL=info
LOG_DIR=./logs
ENABLE_TRANSACTION_LOGGING=true

# --- PAYMENT BUSINESS LOGIC ---
PAYMENT_EXPIRY_TIME=3600
PAYMENT_RETRY_ATTEMPTS=3
PAYMENT_RETRY_INTERVAL=300
MAX_TRANSACTION_AMOUNT=50000000
MIN_TRANSACTION_AMOUNT=10000

# --- OPTIONAL MARKETPLACE APIs ---
TOKOPEDIA_API_KEY=
SHOPEE_API_KEY=
